{
  "setups": [
    "\\pagestyle{fancy}",
    "\\fancyhf{}",
    "\\fancyfoot{}",
    "\\renewcommand{\\headrulewidth}{0pt}",
    "\\renewcommand{\\footrulewidth}{0pt}",
    "\\addtolength{\\oddsidemargin}{-0.5in}",
    "\\addtolength{\\evensidemargin}{0in}",
    "\\addtolength{\\textwidth}{1in}",
    "\\addtolength{\\topmargin}{-.5in}",
    "\\addtolength{\\textheight}{1.0in}",
    "\\urlstyle{same}",
    "\\raggedbottom",
    "\\raggedright",
    "\\setlength{\\tabcolsep}{0in}",
    "\\newfontfamily{\\timesnewroman}{TimesNewRoman}[Path = fonts/, Extension = .ttf]",
    "\\newfontfamily{\\avenirnext}{AvenirNext}[Path = fonts/, Extension = .ttc, UprightFeatures = {FontIndex=7}]",
    "\\newfontfamily{\\avenirnextmedium}{AvenirNext}[Path = fonts/, Extension = .ttc, UprightFeatures = {FontIndex=5}]",
    "\\newfontfamily{\\avenir}{Avenir}[Path = fonts/, Extension = .ttc, UprightFeatures = {FontIndex=0}]",
    "\\newfontfamily{\\avenirheavy}{Avenir}[Path = fonts/, Extension = .ttc, UprightFeatures = {FontIndex=4}]",
    "\\titleformat{\\section}{\n\t\t\\bfseries \\vspace{2pt} \\centering \\large \\color{HeaderBrown} \\avenirnextmedium \\addfontfeatures{LetterSpace=10}\n}{}{0em}{}[\\color{SeparatorPink} \\transparent{0.5} {\\titlerule[0.5pt]} \\vspace{-4pt}]"
  ],
  "newcommands": [
    {
        "command": "newcommand",
        "arguments": "\\resumeItem",
        "options": 1,
        "extra_arguments": "\\item\\avenir\\small{\n\t\t{#1 \\vspace{-1pt}}\n}"
    },
    {
        "command": "renewcommand",
        "arguments": "\\labelitemii",
        "extra_arguments": "$\\vcenter{\\hbox{\\small$\\bullet$}}$"
    },
    {
        "command": "newcommand",
        "arguments": "\\resumeSubHeadingListStart",
        "extra_arguments": "\\begin{itemize}[leftmargin=0in, label={}]"
    },
    {
        "command": "newcommand",
        "arguments": "\\resumeSubHeadingListEnd",
        "extra_arguments": "\\end{itemize}"
    },
    {
        "command": "newcommand",
        "arguments": "\\resumeItemListStart",
        "extra_arguments": "\\begin{itemize}"
    },
    {
        "command": "newcommand",
        "arguments": "\\resumeItemListEnd",
        "extra_arguments": "\\end{itemize}\\vspace{0pt}"
    }
  ]
}
